rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isSuperAdmin() {
      return request.auth != null && getUserData().role == 'superadmin';
    }

    function isShopkeeper() {
      return request.auth != null && getUserData().role == 'shopkeeper';
    }

    function isCustomer() {
      return request.auth != null && getUserData().role == 'customer';
    }

    function isShopOwner(shopId) {
      return isShopkeeper() && getUserData().shopId == shopId;
    }

    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && (
        request.auth.uid == userId ||
        isSuperAdmin()
      );
      allow delete: if isSuperAdmin();
    }

    match /shops/{shopId} {
      allow read: if request.auth != null;
      allow create: if isSuperAdmin();
      allow update: if isSuperAdmin() || isShopOwner(shopId);
      allow delete: if isSuperAdmin();
    }

    match /products/{productId} {
      allow read: if request.auth != null;
      allow create: if isShopkeeper();
      allow update: if request.auth != null;
      allow delete: if isShopkeeper() && resource.data.shopId == getUserData().shopId;
    }

    match /categories/{categoryId} {
      allow read: if request.auth != null;
      allow create: if isShopkeeper();
      allow update: if isShopkeeper() && resource.data.shopId == getUserData().shopId;
      allow delete: if isShopkeeper() && resource.data.shopId == getUserData().shopId;
    }

    match /orders/{orderId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if isShopkeeper() && resource.data.shopId == getUserData().shopId;
      allow delete: if request.auth != null && resource.data.customerId == request.auth.uid;
    }

    match /coupons/{couponId} {
      allow read: if request.auth != null;
      allow create: if isShopkeeper();
      allow update: if isShopkeeper() && resource.data.shopId == getUserData().shopId;
      allow delete: if isShopkeeper() && resource.data.shopId == getUserData().shopId;
    }

    match /reviews/{reviewId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth.uid == resource.data.userId;
      allow delete: if request.auth.uid == resource.data.userId || isSuperAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if isSuperAdmin();
    }
  }
}
